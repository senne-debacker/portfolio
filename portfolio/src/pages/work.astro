---
import Layout from '../layouts/Layout.astro';

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="My Work">
  <section class="page-section">
    <div class="page-header">
      <h1>My Work</h1>
      <p class="lead">A curated selection of design iterations, interactive frameworks, and digital architectures.</p>
    </div>

<div class="work-grid">
  <!-- Project 1 -->
  <a href={`${baseUrl}/work/1`} class="work-card">
    <div class="iframe-placeholder">
      <span>[ Project 1 Preview / Figma Embed ]</span>
    </div>
    <div class="card-meta">
      <h3>Featured Project One</h3>
      <p>View detailed case study &rarr;</p>
    </div>
  </a>

  <!-- Project 2 -->
  <a href={`${baseUrl}/work/2`} class="work-card">
    <div class="iframe-placeholder">
      <span>[ Project 2 Preview / Figma Embed ]</span>
    </div>
    <div class="card-meta">
      <h3>Featured Project Two</h3>
      <p>View detailed case study &rarr;</p>
    </div>
  </a>

  <!-- Project 3 -->
  <a href={`${baseUrl}/work/3`} class="work-card">
    <div class="iframe-placeholder">
      <span>[ Project 3 Preview / Figma Embed ]</span>
    </div>
    <div class="card-meta">
      <h3>Featured Project Three</h3>
      <p>View detailed case study &rarr;</p>
    </div>
  </a>
</div>
  </section>
</Layout>

<style>
  .page-section {
    padding: 3rem 0;
  }
  .page-header {
    margin-bottom: 3rem;
  }
  .page-header h1 {
    font-size: 2.5rem;
    margin-bottom: 0.5rem;
  }
  .lead {
    color: var(--text-muted);
    font-size: 1.1rem;
  }
  .work-grid {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(320px, 1fr));
    gap: 2.5rem;
  }
  .work-card {
    display: block;
    background: #fff;
    border: 1px solid var(--border-color);
    border-radius: 12px;
    overflow: hidden;
    transition: transform 0.2s ease, box-shadow 0.2s ease;
  }
  .work-card:hover {
    transform: translateY(-4px);
    box-shadow: 0 12px 24px rgba(0,0,0,0.04);
  }
  .iframe-placeholder {
    background-color: #f0f0f0;
    border-bottom: 1px solid var(--border-color);
    aspect-ratio: 16 / 9;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #888;
    font-size: 0.85rem;
  }
  .card-meta {
    padding: 1.5rem;
  }
  .card-meta h3 {
    font-size: 1.1rem;
    margin-bottom: 0.25rem;
  }
  .card-meta p {
    font-size: 0.85rem;
    color: var(--accent-color);
  }
</style>