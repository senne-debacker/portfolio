---
import Layout from '../../layouts/Layout.astro';

const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Project One Detail">
  <section class="detail-container">
    <a href={`${baseUrl}/work`} class="back-link">&larr; Back to work</a>
    
    <header class="project-header">
      <h1>Project One Case Study</h1>
      <p class="tagline">UX/UI Design & Creative Frontend Assembly</p>
    </header>

    <div class="main-embed-placeholder">
      <!-- PLACEHOLDER DESCRIPTION: Put a full width High-fidelity live Figma viewport prototype layout or an interactive presentation presentation canvas link embed here -->
      <span>[ Large Project Preview Embed Frame ]</span>
    </div>

    <article class="project-story">
      <h2>The Project</h2>
      <p>This is where you can break down your creative approach, the specific design iteration requirements, prototyping workflow challenges, and engineering tools applied to realize this specific project assignment context during your third year at Devine.</p>
    </article>
  </section>
</Layout>

<style>
  .detail-container {
    padding: 3rem 0;
  }
  .back-link {
    font-size: 0.9rem;
    color: var(--text-muted);
  }
  .project-header {
    margin: 1.5rem 0 3rem 0;
  }
  .project-header h1 {
    font-size: 2.5rem;
  }
  .tagline {
    color: var(--accent-color);
    font-size: 1.1rem;
  }
  .main-embed-placeholder {
    background-color: #f0f0f0;
    border: 2px dashed #ccc;
    border-radius: 12px;
    aspect-ratio: 16 / 10;
    display: flex;
    align-items: center;
    justify-content: center;
    color: #888;
    margin-bottom: 3rem;
  }
  .project-story {
    max-width: 700px;
  }
  .project-story h2 {
    margin-bottom: 1rem;
  }
</style>