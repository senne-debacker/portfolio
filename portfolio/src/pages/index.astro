---
import Layout from '../layouts/Layout.astro';

// Dynamically fetches your base path (e.g., '/portfolio') configured in astro.config.mjs
const baseUrl = import.meta.env.BASE_URL.replace(/\/$/, '');
---

<Layout title="Home">
  <section class="hero animate-fade">
    <div class="hero-content">
      <h1>SENNE DE BACKER</h1>
      <p class="subtitle">UX/UI Designer & Creative Developer</p>
      <p class="location">📍 Buggenhout, Belgium</p>
      
      <div class="quick-nav">
        <!-- Dynamically prefixes your link to prevent 404s on GitHub Pages -->
        <a href={`${baseUrl}/work`} class="main-cta">View My Work &rarr;</a>
      </div>
    </div>
    
    <div class="image-placeholder main-avatar">
      <!-- PLACEHOLDER DESCRIPTION: Put a high-quality professional but creative headshot or a stylized graphic representational of your design style here -->
      <span>[ Image Placeholder: Creative Avatar / Portrait ]</span>
    </div>
  </section>
</Layout>

<style>
  .hero {
    display: grid;
    grid-template-columns: 1.2fr 0.8fr;
    align-items: center;
    gap: 3rem;
    padding: 8rem 0;
  }

  .hero h1 {
    font-size: clamp(2.5rem, 6vw, 4rem);
    line-height: 1.1;
    font-weight: 700;
    margin-bottom: 1rem;
    letter-spacing: -0.02em;
  }

  .subtitle {
    font-size: clamp(1.2rem, 3vw, 1.5rem);
    color: var(--accent-color);
    font-weight: 600;
  }

  .location {
    color: var(--text-muted);
    margin-top: 0.5rem;
  }

  .quick-nav {
    margin-top: 3rem;
  }

  .main-cta {
    background: var(--text-color);
    color: var(--bg-color);
    padding: 0.8rem 1.6rem;
    border-radius: 8px;
    font-weight: 600;
    transition: background 0.2s ease;
  }

  .main-cta:hover {
    background: var(--accent-color);
    color: white;
  }

  .image-placeholder {
    background-color: #f0f0f0;
    border: 2px dashed #ccc;
    border-radius: 8px;
    display: flex;
    align-items: center;
    justify-content: center;
    padding: 2rem;
    text-align: center;
    color: #888;
    font-size: 0.85rem;
  }

  .main-avatar {
    aspect-ratio: 1 / 1;
    border-radius: 50%;
  }

  @media (max-width: 900px) {
    .hero {
      grid-template-columns: 1fr;
      text-align: center;
      gap: 2rem;
      padding: 4rem 0;
    }
    .main-avatar {
      max-width: 240px;
      margin: 0 auto;
      grid-row: 1;
    }
  }
</style>