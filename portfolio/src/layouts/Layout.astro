---
import Header from '../components/Header.astro';
import Footer from '../components/Footer.astro';

interface Props {
	title: string;
	isContactPage?: boolean;
}

const { title, isContactPage = false } = Astro.props;
const base = import.meta.env.BASE_URL;
---

<!doctype html>
<html lang="en">
	<head>
		<meta charset="UTF-8" />
		<meta name="description" content="Senne De Backer - Design Portfolio" />
		<meta name="viewport" content="width=device-width, initial-scale=1.0" />
		<link rel="icon" type="image/svg+xml" href={`${base}favicon.svg`} />
		<title>{title} | Senne De Backer</title>
		<link rel="preconnect" href="https://fonts.googleapis.com">
		<link rel="preconnect" href="https://fonts.gstatic.com" crossorigin>
		<link href="https://fonts.googleapis.com/css2?family=Plus+Jakarta+Sans:ital,wght@0,300;0,400;0,600;0,700;1,400&display=swap" rel="stylesheet">
	</head>
	<body>
		<Header />
		<main class={isContactPage ? "contact-main" : ""}>
			<slot />
		</main>
		{!isContactPage && <Footer />}
	</body>
</html>

<style is:global>
	:root {
		--bg-color: #fcfcfc;
		--text-color: #1a1a1a;
		--accent-color: #4f46e5;
		--text-muted: #666666;
		--border-color: #e5e7eb;
		--max-width: 1100px;
	}

	* {
		box-sizing: border-box;
		margin: 0;
		padding: 0;
	}

	body {
		font-family: 'Plus Jakarta Sans', sans-serif;
		background-color: var(--bg-color);
		color: var(--text-color);
		line-height: 1.6;
		display: flex;
		flex-direction: column;
		min-height: 100vh;
	}

	main {
		flex: 1;
		width: 100%;
		max-width: var(--max-width);
		margin: 0 auto;
		padding: 2rem 1.5rem;
	}

	.contact-main {
		display: flex;
		align-items: center;
		justify-content: center;
	}

	a {
		color: inherit;
		text-decoration: none;
		transition: color 0.2s ease;
	}

	a:hover {
		color: var(--accent-color);
	}

	img {
		max-width: 100%;
		height: auto;
		display: block;
	}
</style>